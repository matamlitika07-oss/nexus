  const el=document.getElementById('holdingsList');
  el.innerHTML=holdings.map(h=>`
    <div class="holding">
      <div><div class="holding-name">${h.name}</div><div class="holding-shares">${h.shares} shares</div></div>
      <div class="holding-val">$${h.value.toFixed(2)} <span style="font-size:0.72rem;color:${h.pct>=0?'var(--accent)':'var(--red)'}"> ${h.pct>=0?'▲':'▼'}${Math.abs(h.pct)}%</span></div>
    </div>`).join('');
}
 
// ===== QUIZ =====
let currentQ=0,score=0,answered=false;
function buildQuizProgress(){
  const el=document.getElementById('quizProgress');
  el.innerHTML=quizData.map((_,i)=>`<div class="qp-dot ${i<currentQ?'done':i===currentQ?'active':''}"></div>`).join('');
}
function loadQuestion(){
  if(currentQ>=quizData.length){
    document.getElementById('quizCard').innerHTML=`<div style="text-align:center;padding:2rem"><div style="font-size:3rem;margin-bottom:1rem">🏆</div><h3 style="font-family:Syne,sans-serif;font-weight:800;font-size:1.8rem;margin-bottom:0.5rem">Quiz Complete!</h3><p style="color:var(--muted);margin-bottom:1.5rem">You scored ${score}/${quizData.length} — ${Math.round(score/quizData.length*100)}%</p><button class="btn-primary" onclick="resetQuiz()">Retake Quiz</button></div>`;
    return;
  }
  const q=quizData[currentQ];answered=false;
  document.getElementById('quizLevel').textContent=q.level;
  document.getElementById('quizQuestion').textContent=q.q;
  document.getElementById('quizOptions').innerHTML=q.opts.map((o,i)=>`<button class="quiz-opt" onclick="selectAnswer(${i})">${o}</button>`).join('');
  const fb=document.getElementById('quizFeedback');fb.className='quiz-feedback';fb.textContent='';
  document.getElementById('quizNext').className='quiz-next';
  buildQuizProgress();
}
function selectAnswer(i){
  if(answered)return;answered=true;
  const q=quizData[currentQ];
  const opts=document.querySelectorAll('.quiz-opt');
  opts.forEach((o,j)=>{o.classList.add('disabled');if(j===q.correct)o.classList.add('correct');else if(j===i&&i!==q.correct)o.classList.add('wrong');});
  const fb=document.getElementById('quizFeedback');
  if(i===q.correct){score++;fb.className='quiz-feedback show good';fb.textContent='✓ Correct! '+q.explain;}
  else{fb.className='quiz-feedback show bad';fb.textContent='✗ Not quite. '+q.explain;}
  document.getElementById('quizNext').className='quiz-next show';
  const xp=score*20;
  document.getElementById('xpFill').style.width=Math.min(xp/120*100,100)+'%';
  document.getElementById('scoreDisplay').textContent='XP: '+xp;
}
function nextQuestion(){currentQ++;loadQuestion();}
function resetQuiz(){
  currentQ=0;score=0;
  document.getElementById('quizCard').innerHTML='<div class="quiz-level" id="quizLevel"></div><div class="quiz-q" id="quizQuestion"></div><div class="quiz-options" id="quizOptions"></div><div class="quiz-feedback" id="quizFeedback"></div><button class="quiz-next" id="quizNext" onclick="nextQuestion()">Next Question →</button>';
  document.getElementById('xpFill').style.width='0%';
  document.getElementById('scoreDisplay').textContent='XP: 0';
  loadQuestion();
}
 
// ===== CHALLENGES =====
function renderChallenges(){
  const el=document.getElementById('challengeGrid');
  el.innerHTML=challenges.map((c,i)=>`
    <div class="challenge-card" onclick="joinChallenge(${i})">
      <div class="ch-header"><span class="ch-emoji">${c.emoji}</span><span class="ch-badge badge-${c.badge}">${c.badge==='active'?'Active':c.badge==='new'?'New':'Completed'}</span></div>
      <div class="ch-title">${c.title}</div>
      <div class="ch-desc">${c.desc}</div>
      <div class="ch-progress">
        <div class="ch-prog-bar"><div class="ch-prog-fill" style="width:${c.progress}%"></div></div>
        <div class="ch-prog-label"><span>${c.current}/${c.goal}</span><span>${c.progress}%</span></div>
      </div>
      <div class="ch-reward">🏅 ${c.reward}</div>
    </div>`).join('');
}
function joinChallenge(i){
  const c=challenges[i];
  if(c.badge==='done'){showToast('✅ Completed!','You already crushed this challenge!');return;}
  showToast('🎯 Joined!','You are in the "'+c.title+'" challenge. Let\'s go!');
}
 
// ===== LEADERBOARD =====
function renderLeaderboard(){
  const el=document.getElementById('leaderboardBody');
  el.innerHTML=leaderboard.map(r=>`
    <tr>
      <td class="lb-rank ${r.rank<=3?'rank-'+r.rank:''}">${r.rank===1?'🥇':r.rank===2?'🥈':r.rank===3?'🥉':r.rank}</td>
      <td><div class="lb-name-wrap"><div class="lb-avatar" style="background:${r.color}33;color:${r.color}">${r.avatar}</div><div><div class="lb-name">${r.name}</div><div class="lb-school">${r.school}</div></div></div></td>
      <td class="lb-savings">${r.saved}</td>
      <td class="lb-streak">${r.streak}</td>
      <td><span class="lb-level">${r.level==='Gold'?'🥇':r.level==='Silver'?'🥈':'🥉'} ${r.level}</span></td>
    </tr>`).join('');
}
 
// ===== TOAST =====
let toastTimer;
function showToast(title,msg){
  clearTimeout(toastTimer);
  document.getElementById('toastTitle').textContent=title;
  document.getElementById('toastMsg').textContent=msg;
  const t=document.getElementById('toast');t.classList.add('show');
  toastTimer=setTimeout(()=>t.classList.remove('show'),4000);
}
 
// ===== MODAL =====
function openModal(){document.getElementById('modal').classList.add('open');}
function closeModal(){document.getElementById('modal').classList.remove('open');}
document.getElementById('modal').addEventListener('click',function(e){if(e.target===this)closeModal();});
 
// ===== LIVE PRICE SIM =====
function animatePrices(){
  stocks.forEach(s=>{
    const delta=(Math.random()-0.48)*s.price*0.003;
    s.price=Math.max(1,s.price+delta);s.change=delta;s.pct=(delta/s.price)*100;
  });
  renderStocks();
}
 
// ===== INIT =====
window.addEventListener('DOMContentLoaded',()=>{
  buildTicker();renderExpenses();updateCompound();renderStocks();loadQuestion();renderChallenges();renderLeaderboard();
  setInterval(animatePrices,5000);
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.style.animation='fadeUp 0.5s ease both';}});
  },{threshold:0.1});
  document.querySelectorAll('.card,.step,.challenge-card').forEach(el=>obs.observe(el));
});
</script>
</body>
</html>
