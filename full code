// ===== COMPOUND CHART =====
function updateCompound(){
  const monthly=+document.getElementById('monthlyInput').value;
  const rate=+document.getElementById('returnInput').value/100/12;
  const years=+document.getElementById('yearsInput').value;
  document.getElementById('monthlyVal').textContent='$'+monthly;
  document.getElementById('returnVal').textContent=document.getElementById('returnInput').value+'%';
  document.getElementById('yearsVal').textContent=years+' yrs';
  const months=years*12;let bal=0,contrib=0;const pts=[];
  for(let i=0;i<=months;i++){bal=bal*(1+rate)+monthly;contrib+=monthly;pts.push({b:bal,c:contrib});}
  drawChart(pts);
  const final=pts[pts.length-1].b,contributed=monthly*months,gains=final-contributed;
  document.getElementById('compoundResult').innerHTML=`
    <div class="cr-item"><div class="cr-val">$${Math.round(final).toLocaleString()}</div><div class="cr-label">Final Value</div></div>
    <div class="cr-item"><div class="cr-val">$${Math.round(contributed).toLocaleString()}</div><div class="cr-label">Contributed</div></div>
    <div class="cr-item"><div class="cr-val" style="color:var(--gold)">$${Math.round(gains).toLocaleString()}</div><div class="cr-label">Market Gains</div></div>`;
}
function drawChart(pts){
  const canvas=document.getElementById('compoundChart');
  const dpr=window.devicePixelRatio||1;
  const W=canvas.parentElement.offsetWidth-64||500,H=200;
  canvas.width=W*dpr;canvas.height=H*dpr;canvas.style.width=W+'px';canvas.style.height=H+'px';
  const ctx=canvas.getContext('2d');ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,W,H);
  const maxVal=Math.max(...pts.map(p=>p.b));
  const step=W/(pts.length-1||1);
  ctx.beginPath();
  pts.forEach((p,i)=>{const x=i*step,y=H-H*(p.b/maxVal);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
  const grad=ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0,'rgba(0,232,122,0.3)');grad.addColorStop(1,'rgba(0,232,122,0)');
  ctx.fillStyle=grad;ctx.fill();
  ctx.beginPath();
  pts.forEach((p,i)=>{const x=i*step,y=H-H*(p.c/maxVal);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
  ctx.fillStyle='rgba(245,200,66,0.12)';ctx.fill();
  ctx.beginPath();
  pts.forEach((p,i)=>{const x=i*step,y=H-H*(p.b/maxVal);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.strokeStyle='#00e87a';ctx.lineWidth=2;ctx.stroke();
  ctx.beginPath();
  pts.forEach((p,i)=>{const x=i*step,y=H-H*(p.c/maxVal);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.strokeStyle='rgba(245,200,66,0.5)';ctx.lineWidth=1.5;ctx.setLineDash([4,3]);ctx.stroke();ctx.setLineDash([]);
}
 
