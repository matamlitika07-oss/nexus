function drawMiniChart(id,up){
  const c=document.getElementById(id);if(!c)return;
  const ctx=c.getContext('2d');const W=60,H=28;
  const pts=Array.from({length:10},(_,i)=>10+Math.random()*8*(up?1:-0.2)*i+(Math.random()-0.5)*4);
  const mn=Math.min(...pts),mx=Math.max(...pts);
  ctx.clearRect(0,0,W,H);
  ctx.beginPath();
  pts.forEach((p,i)=>{const x=i*(W/(pts.length-1)),y=H-(H*(p-mn)/(mx-mn||1));i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.strokeStyle=up?'#00e87a':'#ff4d6d';ctx.lineWidth=1.5;ctx.stroke();
}
