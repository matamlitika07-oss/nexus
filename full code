<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CoinUp — Student Micro-Wealth Sandbox</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0f0d;
    --surface: #111a15;
    --surface2: #162019;
    --accent: #00e87a;
    --accent2: #00b85e;
    --accent-dim: rgba(0,232,122,0.12);
    --gold: #f5c842;
    --red: #ff4d6d;
    --text: #e8f5ee;
    --muted: #6b8c78;
    --border: rgba(0,232,122,0.15);
    --glow: 0 0 30px rgba(0,232,122,0.2);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;line-height:1.6}
  body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:0.4}
  nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.2rem 2.5rem;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(20px);background:rgba(10,15,13,0.85);border-bottom:1px solid var(--border)}
  .logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--accent);letter-spacing:-0.5px}
  .logo span{color:var(--text)}
  nav ul{list-style:none;display:flex;gap:2rem}
  nav ul a{color:var(--muted);text-decoration:none;font-size:0.9rem;font-family:'DM Mono',monospace;transition:color 0.2s}
  nav ul a:hover{color:var(--accent)}
  .nav-cta{background:var(--accent);color:#000;border:none;padding:0.55rem 1.4rem;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:0.85rem;cursor:pointer;transition:all 0.2s}
  .nav-cta:hover{background:#fff;transform:scale(1.04)}
  #hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:6rem 2rem 4rem;position:relative;overflow:hidden}
  .hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 20%, rgba(0,232,122,0.08) 0%, transparent 70%)}
  .hero-grid{position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:60px 60px;opacity:0.4}
  .hero-content{position:relative;z-index:2;max-width:820px}
  .hero-badge{display:inline-flex;align-items:center;gap:0.5rem;background:var(--accent-dim);border:1px solid var(--border);border-radius:50px;padding:0.4rem 1rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:var(--accent);margin-bottom:2rem;animation:fadeUp 0.6s ease both}
  .hero-badge .dot{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
  h1{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(2.8rem,7vw,5.5rem);line-height:1.05;letter-spacing:-2px;animation:fadeUp 0.7s ease 0.1s both}
  h1 .hl{color:var(--accent);position:relative}
  h1 .hl::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:3px;background:var(--accent);border-radius:2px}
  .hero-sub{font-size:1.1rem;color:var(--muted);max-width:560px;margin:1.5rem auto 2.5rem;font-weight:300;animation:fadeUp 0.7s ease 0.2s both}
  .hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;animation:fadeUp 0.7s ease 0.3s both}
  .btn-primary{background:var(--accent);color:#000;border:none;padding:0.85rem 2.2rem;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;cursor:pointer;transition:all 0.25s;box-shadow:0 0 30px rgba(0,232,122,0.3)}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 0 50px rgba(0,232,122,0.5)}
  .btn-outline{background:transparent;color:var(--text);border:1px solid var(--border);padding:0.85rem 2.2rem;border-radius:50px;font-family:'Syne',sans-serif;font-weight:600;font-size:1rem;cursor:pointer;transition:all 0.25s}
  .btn-outline:hover{border-color:var(--accent);color:var(--accent)}
  .hero-stats{display:flex;gap:3rem;justify-content:center;margin-top:4rem;animation:fadeUp 0.7s ease 0.4s both;flex-wrap:wrap}
  .stat{text-align:center}
  .stat-num{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent)}
  .stat-label{font-size:0.8rem;color:var(--muted);font-family:'DM Mono',monospace}
  section{padding:5rem 2rem}
  .container{max-width:1200px;margin:0 auto}
  .section-tag{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:0.8rem}
  .section-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(1.8rem,4vw,3rem);letter-spacing:-1px;margin-bottom:1rem}
  .section-sub{color:var(--muted);max-width:520px;font-size:1rem}
  #tracker{background:var(--surface)}
  .tracker-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:3rem}
  @media(max-width:768px){.tracker-grid{grid-template-columns:1fr}.portfolio-grid{grid-template-columns:1fr!important}nav ul{display:none}}
  .card{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:2rem}
  .card h3{font-family:'Syne',sans-serif;font-weight:700;font-size:1.1rem;margin-bottom:1.5rem;color:var(--text)}
  .expense-list{display:flex;flex-direction:column;gap:0.75rem;margin-bottom:1.5rem;max-height:260px;overflow-y:auto}
  .expense-item{display:flex;align-items:center;justify-content:space-between;padding:0.85rem 1rem;background:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.05)}
  .exp-left{display:flex;align-items:center;gap:0.75rem}
  .exp-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
  .exp-name{font-size:0.9rem;font-weight:500}
  .exp-cat{font-size:0.75rem;color:var(--muted);font-family:'DM Mono',monospace}
  .exp-right{text-align:right}
  .exp-amount{font-family:'DM Mono',monospace;font-size:0.95rem;font-weight:500}
  .exp-roundup{font-size:0.72rem;color:var(--accent);font-family:'DM Mono',monospace}
  .add-expense{display:flex;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap}
  .add-expense input{flex:1;min-width:100px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:10px;padding:0.65rem 1rem;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.9rem;outline:none;transition:border-color 0.2s}
  .add-expense input:focus{border-color:var(--accent)}
  .add-expense input::placeholder{color:var(--muted)}
  .add-expense button{background:var(--accent);color:#000;border:none;padding:0.65rem 1.2rem;border-radius:10px;font-family:'Syne',sans-serif;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap}
  .add-expense button:hover{background:#00ff88}
  .roundup-summary{background:var(--accent-dim);border:1px solid var(--border);border-radius:14px;padding:1.2rem;text-align:center}
  .roundup-label{font-size:0.8rem;color:var(--muted);font-family:'DM Mono',monospace;margin-bottom:0.3rem}
  .roundup-amount{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent)}
  .roundup-sub{font-size:0.78rem;color:var(--muted);margin-top:0.3rem}
  .invest-btn{width:100%;margin-top:1rem;background:var(--accent);color:#000;border:none;padding:0.85rem;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;font-size:0.95rem;cursor:pointer;transition:all 0.2s;box-shadow:var(--glow)}
  .invest-btn:hover{transform:translateY(-2px)}
  .compound-controls{display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap}
  .ctrl-group{display:flex;flex-direction:column;gap:0.3rem;flex:1;min-width:100px}
  .ctrl-group label{font-size:0.75rem;color:var(--muted);font-family:'DM Mono',monospace}
  .ctrl-group input[type=range]{width:100%;accent-color:var(--accent)}
  .ctrl-group .val{font-family:'DM Mono',monospace;font-size:0.85rem;color:var(--accent)}
  canvas#compoundChart{width:100%;height:200px;display:block}
  .compound-result{display:flex;justify-content:space-between;margin-top:1rem;padding:1rem;background:rgba(0,232,122,0.07);border-radius:12px;flex-wrap:wrap;gap:0.5rem}
  .cr-item{text-align:center}
  .cr-val{font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;color:var(--accent)}
  .cr-label{font-size:0.72rem;color:var(--muted);font-family:'DM Mono',monospace}
  #portfolio{background:var(--bg)}
  .portfolio-grid{display:grid;grid-template-columns:2fr 1fr;gap:2rem;margin-top:3rem}
  .stock-table{width:100%;border-collapse:collapse}
  .stock-table th{font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--muted);text-transform:uppercase;text-align:left;padding:0.7rem 1rem;border-bottom:1px solid var(--border)}
  .stock-table td{padding:0.9rem 1rem;border-bottom:1px solid rgba(255,255,255,0.04);font-size:0.9rem;vertical-align:middle}
  .stock-table tr:hover td{background:rgba(255,255,255,0.02)}
  .stock-name{font-weight:600;font-size:0.95rem}
  .stock-ticker{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--muted)}
  .stock-price{font-family:'DM Mono',monospace;font-size:0.95rem}
  .change-pos{color:var(--accent);font-family:'DM Mono',monospace;font-size:0.85rem;font-weight:600}
  .change-neg{color:var(--red);font-family:'DM Mono',monospace;font-size:0.85rem;font-weight:600}
  .buy-btn{background:var(--accent-dim);border:1px solid var(--border);color:var(--accent);padding:0.35rem 0.85rem;border-radius:8px;font-family:'Syne',sans-serif;font-weight:700;font-size:0.8rem;cursor:pointer;transition:all 0.2s}
  .buy-btn:hover{background:var(--accent);color:#000}
  .mini-chart{display:inline-block;width:60px;height:28px;vertical-align:middle}
  .portfolio-summary{display:flex;flex-direction:column;gap:1rem}
  .balance-card{background:linear-gradient(135deg,var(--accent) 0%,var(--accent2) 100%);border-radius:20px;padding:1.8rem;color:#000}
  .balance-label{font-family:'DM Mono',monospace;font-size:0.78rem;font-weight:500;opacity:0.7;margin-bottom:0.4rem}
  .balance-amount{font-family:'Syne',sans-serif;font-size:2.4rem;font-weight:800}
  .balance-change{font-family:'DM Mono',monospace;font-size:0.82rem;margin-top:0.4rem;opacity:0.8}
  .holdings-list{display:flex;flex-direction:column;gap:0.6rem}
  .holding{display:flex;justify-content:space-between;align-items:center;padding:0.7rem 0;border-bottom:1px solid var(--border)}
  .holding:last-child{border-bottom:none}
  .holding-name{font-size:0.88rem;font-weight:500}
  .holding-shares{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--muted)}
  .holding-val{font-family:'DM Mono',monospace;font-size:0.9rem;color:var(--accent);font-weight:500}
  #quiz{background:var(--surface)}
  .quiz-wrapper{max-width:720px;margin:3rem auto 0}
  .quiz-progress{display:flex;gap:0.5rem;margin-bottom:2rem}
  .qp-dot{flex:1;height:4px;border-radius:2px;background:var(--border);transition:background 0.3s}
  .qp-dot.done{background:var(--accent)}
  .qp-dot.active{background:var(--accent);box-shadow:0 0 10px var(--accent)}
  .quiz-card{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:2.5rem;animation:fadeUp 0.4s ease both}
  .quiz-level{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--accent);margin-bottom:0.5rem}
  .quiz-q{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:700;margin-bottom:2rem;line-height:1.4}
  .quiz-options{display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2rem}
  .quiz-opt{background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:12px;padding:1rem 1.2rem;cursor:pointer;transition:all 0.2s;font-size:0.95rem;text-align:left;color:var(--text);width:100%;font-family:'DM Sans',sans-serif}
  .quiz-opt:hover{border-color:var(--accent);background:var(--accent-dim)}
  .quiz-opt.correct{border-color:var(--accent);background:rgba(0,232,122,0.15);color:var(--accent)}
  .quiz-opt.wrong{border-color:var(--red);background:rgba(255,77,109,0.1);color:var(--red)}
  .quiz-opt.disabled{pointer-events:none}
  .quiz-feedback{padding:1rem 1.2rem;border-radius:12px;font-size:0.9rem;margin-bottom:1.5rem;display:none}
  .quiz-feedback.show{display:block}
  .quiz-feedback.good{background:rgba(0,232,122,0.1);border:1px solid var(--border);color:var(--accent)}
  .quiz-feedback.bad{background:rgba(255,77,109,0.1);border:1px solid rgba(255,77,109,0.3);color:var(--red)}
  .quiz-next{background:var(--accent);color:#000;border:none;padding:0.75rem 2rem;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;cursor:pointer;transition:all 0.2s;display:none}
  .quiz-next.show{display:inline-block}
  .quiz-next:hover{background:#00ff88;transform:scale(1.04)}
  .xp-bar-wrap{margin-bottom:1.5rem}
  .xp-label{display:flex;justify-content:space-between;font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--muted);margin-bottom:0.4rem}
  .xp-bar{height:8px;background:var(--border);border-radius:4px;overflow:hidden}
  .xp-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--gold));border-radius:4px;transition:width 0.5s ease;width:0%}
  .score-display{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:var(--gold)}
  #challenges{background:var(--bg)}
  .challenge-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;margin-top:3rem}
  .challenge-card{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:1.8rem;transition:all 0.25s;cursor:pointer;position:relative;overflow:hidden}
  .challenge-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--accent-dim),transparent);opacity:0;transition:opacity 0.25s}
  .challenge-card:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:var(--glow)}
  .challenge-card:hover::before{opacity:1}
  .ch-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem;position:relative}
  .ch-emoji{font-size:2rem}
  .ch-badge{font-family:'DM Mono',monospace;font-size:0.7rem;padding:0.25rem 0.65rem;border-radius:50px;font-weight:500}
  .badge-active{background:rgba(0,232,122,0.15);color:var(--accent);border:1px solid var(--border)}
  .badge-new{background:rgba(245,200,66,0.15);color:var(--gold);border:1px solid rgba(245,200,66,0.3)}
  .badge-done{background:rgba(255,255,255,0.07);color:var(--muted);border:1px solid rgba(255,255,255,0.1)}
  .ch-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:0.4rem;position:relative}
  .ch-desc{font-size:0.85rem;color:var(--muted);margin-bottom:1.2rem;position:relative}
  .ch-progress{position:relative}
  .ch-prog-bar{height:6px;background:var(--border);border-radius:3px;overflow:hidden;margin-bottom:0.5rem}
  .ch-prog-fill{height:100%;background:var(--accent);border-radius:3px;transition:width 1s ease}
  .ch-prog-label{display:flex;justify-content:space-between;font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--muted)}
  .ch-reward{display:flex;align-items:center;gap:0.4rem;margin-top:1rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:var(--gold);position:relative}
  #leaderboard{background:var(--surface)}
  .lb-table{width:100%;border-collapse:collapse}
  .lb-table th{font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--muted);text-transform:uppercase;text-align:left;padding:0.7rem 1rem;border-bottom:1px solid var(--border)}
  .lb-table td{padding:0.95rem 1rem;border-bottom:1px solid rgba(255,255,255,0.04)}
  .lb-table tr:hover td{background:rgba(255,255,255,0.02)}
  .lb-rank{font-family:'DM Mono',monospace;font-size:0.9rem;font-weight:500;width:50px}
  .rank-1{color:var(--gold)}.rank-2{color:#c0c0c0}.rank-3{color:#cd7f32}
  .lb-avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.9rem;margin-right:0.75rem;flex-shrink:0}
  .lb-name-wrap{display:flex;align-items:center}
  .lb-name{font-weight:600;font-size:0.95rem}
  .lb-school{font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--muted)}
  .lb-savings{font-family:'DM Mono',monospace;font-size:0.95rem;color:var(--accent);font-weight:600}
  .lb-streak{font-family:'DM Mono',monospace;font-size:0.85rem;color:var(--gold)}
  .lb-level{display:inline-flex;align-items:center;gap:0.3rem;background:var(--accent-dim);border:1px solid var(--border);border-radius:50px;padding:0.2rem 0.6rem;font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--accent)}
  #how{background:var(--bg)}
  .steps{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.5rem;margin-top:3rem}
  .step{padding:2rem 1.5rem;background:var(--surface2);border:1px solid var(--border);border-radius:20px;transition:all 0.25s}
  .step:hover{border-color:var(--accent);transform:translateY(-4px)}
  .step-num{font-family:'Syne',sans-serif;font-weight:800;font-size:3rem;color:var(--accent);opacity:0.25;line-height:1;margin-bottom:0.5rem}
  .step-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:0.5rem}
  .step-desc{font-size:0.85rem;color:var(--muted)}
  footer{background:var(--surface);border-top:1px solid var(--border);padding:3rem 2rem;text-align:center}
  .footer-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.8rem;color:var(--accent);margin-bottom:0.5rem}
  .footer-sub{color:var(--muted);font-size:0.85rem;margin-bottom:1.5rem}
  .footer-links{display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;margin-bottom:2rem}
  .footer-links a{color:var(--muted);text-decoration:none;font-size:0.85rem;font-family:'DM Mono',monospace;transition:color 0.2s}
  .footer-links a:hover{color:var(--accent)}
  .footer-copy{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--muted)}
  .toast{position:fixed;bottom:2rem;right:2rem;background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:1rem 1.5rem;font-size:0.9rem;z-index:9999;transform:translateX(150%);transition:transform 0.35s ease;max-width:300px;box-shadow:0 8px 40px rgba(0,0,0,0.4)}
  .toast.show{transform:translateX(0)}
  .toast .t-title{font-family:'Syne',sans-serif;font-weight:700;color:var(--accent);margin-bottom:0.2rem}
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(8px);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity 0.3s}
  .modal-overlay.open{opacity:1;pointer-events:all}
  .modal{background:var(--surface2);border:1px solid var(--border);border-radius:24px;padding:2.5rem;max-width:480px;width:100%;transform:scale(0.95);transition:transform 0.3s;position:relative}
  .modal-overlay.open .modal{transform:scale(1)}
  .modal h3{font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;margin-bottom:0.5rem}
  .modal p{color:var(--muted);font-size:0.9rem;margin-bottom:1.5rem}
  .modal-close{position:absolute;top:1rem;right:1rem;background:rgba(255,255,255,0.1);border:none;color:var(--text);width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center}
  .modal-input{width:100%;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:10px;padding:0.8rem 1rem;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.95rem;outline:none;margin-bottom:0.75rem}
  .modal-input:focus{border-color:var(--accent)}
  .ticker-wrap{overflow:hidden;background:rgba(0,232,122,0.05);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:0.6rem 0}
  .ticker-track{display:flex;white-space:nowrap;animation:ticker 30s linear infinite}
  .ticker-item{padding:0 2.5rem;font-family:'DM Mono',monospace;font-size:0.8rem;color:var(--muted)}
